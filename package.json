{
  "name": "workspace",
  "version": "1.0.0",
  "license": "MIT",
  "private": true,

  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",

    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts",

    "typecheck": "tsc --noEmit"
  },

  "dependencies": {
    "express": "^4.19.2"
  },

  "devDependencies": {
    "typescript": "~5.9.2",
    "ts-node": "^10.9.1",
    "@types/node": "^20.11.30",
    "prettier": "^3.8.1"
  }
}
