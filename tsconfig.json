{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "commonjs",
    "target": "es2019",
    "esModuleInterop": true,
    "moduleResolution": "node16",
    "baseUrl": ".",
    "paths": {
      "@workspace/*": ["lib/*"]
    },
    "skipLibCheck": true,
    "strict": false
  },
  "include": [
    "artifacts/api-server/src/**/*",
    "lib/**/*"
  ]
}
